# ─────────────────────────────────────────────────────────────────────
# Santa Paciência — Variáveis de Ambiente (template)
# ─────────────────────────────────────────────────────────────────────
# Copia este ficheiro para `.env` (mesma pasta) e preenche os valores.
# NUNCA commitar `.env` para o git — já está no .gitignore.

# ─── Servidor ──────────────────────────────────────────────────────────
NODE_ENV=production                   # development | production
PORT=3001
DB_PATH=/app/data/santapaciencia.db
FRONTEND_PATH=/app/frontend           # caminho absoluto para /frontend em prod

# ─── Identidade da propriedade (fallback caso a org não tenha settings) ─
PROPERTY_NAME=Santa Paciência
PROPERTY_ADDRESS=
LICENSE_NUMBER=

# ─── Sessões ────────────────────────────────────────────────────────────
SESSION_TTL_DAYS=14
COOKIE_SECURE=false                   # true para forçar HTTPS-only (auto em production)

# ─── Email SMTP (Nodemailer — fallback ao Gmail OAuth) ──────────────────
EMAIL_ENABLED=true
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=                           # senha de aplicação Gmail (16 chars)
EMAIL_FROM="Santa Paciência <email@gmail.com>"

# ─── Google OAuth (Calendar + Gmail + Tasks) ────────────────────────────
# Obter em https://console.cloud.google.com → APIs & Services → Credentials
# Usar o mesmo GOOGLE_CLIENT_ID/SECRET para os 3 fluxos; registar os 3
# redirect URIs em "Authorized redirect URIs".
# GOOGLE_CLIENT_SECRET é também usado como chave HMAC para o `state` OAuth (CSRF).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
GOOGLE_EMAIL_REDIRECT_URI=http://localhost:3001/auth/google-email/callback
GOOGLE_TASKS_REDIRECT_URI=http://localhost:3001/auth/google-tasks/callback

# ─── Cloudflare Turnstile (CAPTCHA reserva pública) ─────────────────────
# Obter em https://dash.cloudflare.com → Turnstile → Add Widget
# O widget é limitado por hostname: incluir o domínio de produção e, para
# testar em dev, adicionar `localhost` aos hostnames do widget.
# Em produção sem `TURNSTILE_SECRET_KEY` → reservas públicas REJEITADAS
# (fail-closed). Em dev podes deixar vazio (a verificação é saltada).
# Chaves de TESTE oficiais (passam sempre, qualquer domínio — só para dev):
#   TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Scheduler de reservas ──────────────────────────────────────────────
PUBLIC_PENDING_TTL_HOURS=48           # cancela reservas pendentes do website >X horas sem pagamento
PENDING_EXPIRY_INTERVAL_MS=1800000    # intervalo do scheduler (default 30 min)
