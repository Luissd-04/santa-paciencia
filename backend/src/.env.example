# Servidor
PORT=3001
NODE_ENV=production

# Base de dados (caminho dentro do container Docker)
DB_PATH=/app/data/santapaciencia.db

# Frontend (servido pelo Express em produção)
FRONTEND_PATH=/app/frontend

# Google OAuth (Calendar + Gmail)
# Usar o mesmo GOOGLE_CLIENT_ID e GOOGLE_CLIENT_SECRET para ambos.
# Registar AMBOS os redirect URIs no Google Cloud Console:
#   https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Calendar callback (AVISO: muda com o Cloudflare Quick Tunnel)
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
# Gmail callback — adicionar também no Google Cloud Console
GOOGLE_EMAIL_REDIRECT_URI=http://localhost:3001/auth/google-email/callback

# Email de fallback via SMTP (usado se o Gmail OAuth não estiver ligado)
EMAIL_ENABLED=true
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Santa Paciência <email@gmail.com>"

# Licença do Alojamento
LICENSE_NUMBER=
PROPERTY_NAME=Santa Paciência
PROPERTY_ADDRESS=
