# Servidor
PORT=3001
NODE_ENV=production

# Base de dados (caminho absoluto recomendado no servidor)
DB_PATH=/data/santapaciencia.db

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Email (Nodemailer via Gmail ou SMTP)
EMAIL_ENABLED=true
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Santa Paciência <email@gmail.com>"

# Licença do Alojamento
LICENSE_NUMBER=
PROPERTY_NAME=Santa Paciência
PROPERTY_ADDRESS=
